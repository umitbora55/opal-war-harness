{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "opal-war-harness",
      "folder": "opal",
      "interval": "1m",
      "rules": [
        {
          "uid": "alert-trust-false-progression",
          "title": "Trust False Progression",
          "condition": "A",
          "data": [
            {
              "refId": "A",
              "queryType": "timeSeriesQuery",
              "relativeTimeRange": {
                "from": 60,
                "to": 0
              },
              "datasourceUid": "prometheus",
              "model": {
                "expr": "trust_false_progression",
                "legendFormat": "trust_false_progression"
              }
            }
          ],
          "for": "1m",
          "noDataState": "Alerting",
          "execErrState": "Alerting",
          "labels": {
            "severity": "critical",
            "blocking": "true"
          },
          "annotations": {
            "summary": "Trust False Progression",
            "runName": "opal-war-base"
          }
        },
        {
          "uid": "alert-duplicate-state",
          "title": "Duplicate State",
          "condition": "A",
